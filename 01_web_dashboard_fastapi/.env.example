# Dashboard local template.
# Root .env.example is the source of truth for the whole project.
# Copy to 01_web_dashboard_fastapi/.env only for local dashboard-only tests.

DASHBOARD_USERNAME=admin

# Recommended: generate a hash with:
# python scripts/make_password_hash.py your-password
DASHBOARD_PASSWORD_HASH=PUT_GENERATED_PASSWORD_HASH_HERE

# Local testing fallback only. Leave empty when DASHBOARD_PASSWORD_HASH is set.
DASHBOARD_PASSWORD=

DASHBOARD_SECRET_KEY=PUT_LONG_RANDOM_SECRET_HERE
SESSION_SECRET=
SESSION_MAX_AGE_SECONDS=86400
COOKIE_SECURE=false

DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
DASHBOARD_ENABLE_SYSTEMCTL=false
DASHBOARD_ENABLE_BACKUP=true

PHONE_AI_BASE_URL=http://192.168.0.50:8080
PHONE_AI_API_TOKEN=PUT_PHONE_AI_TOKEN_HERE
PHONE_AI_TIMEOUT_SECONDS=30

NAS_BACKUP_TARGET=user@192.168.0.20:/volume1/minecraft_backups/raspberry_pi
BACKUP_KEEP_COUNT=5
BACKUP_TIME=03:30
BACKUP_INTERVAL_DAYS=3
BACKUP_SKIP_CUTOFF=23:59
