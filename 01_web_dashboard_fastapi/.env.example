# Dashboard local template.
# Root .env.example is the source of truth for the whole project.
# Copy to 01_web_dashboard_fastapi/.env only for local dashboard-only tests.

DASHBOARD_USERNAME=admin

# Recommended: generate a hash with:
# python scripts/make_password_hash.py your-password
DASHBOARD_PASSWORD_HASH=PUT_GENERATED_PASSWORD_HASH_HERE

# Local testing fallback only. Leave empty when DASHBOARD_PASSWORD_HASH is set.
DASHBOARD_PASSWORD=

DASHBOARD_SECRET_KEY=PUT_LONG_RANDOM_SECRET_HERE
SESSION_SECRET=
SESSION_MAX_AGE_SECONDS=86400
COOKIE_SECURE=false

NEWS_ADMIN_USERNAME=PUT_NEWS_ADMIN_USERNAME_HERE
NEWS_ADMIN_PASSWORD_HASH=PUT_GENERATED_NEWS_PASSWORD_HASH_HERE
NEWS_SESSION_SECRET=PUT_LONG_RANDOM_NEWS_SESSION_SECRET_HERE
NEWS_SESSION_MAX_AGE_SECONDS=86400
NEWS_COOKIE_SECURE=false
NEWS_DB_PATH=

COMMUNITY_DB_PATH=
COMMUNITY_HASH_SECRET=PUT_LONG_RANDOM_COMMUNITY_HASH_SECRET_HERE
COMMUNITY_MODERATION_ENABLED=true
COMMUNITY_MODERATION_PROVIDER=llamacpp
COMMUNITY_MODERATION_BASE_URL=http://127.0.0.1:8088
COMMUNITY_MODERATION_MODEL=qwen2.5-0.5b-instruct
COMMUNITY_MODERATION_TIMEOUT_SECONDS=5
COMMUNITY_MODERATION_FAIL_MODE=pending_review
COMMUNITY_MODERATION_AUTO_HIDE=true
COMMUNITY_MODERATION_MAX_CHARS=1200
COMMUNITY_REPORT_THRESHOLD=3
COMMUNITY_MAX_POST_LENGTH=3000
COMMUNITY_MAX_COMMENT_LENGTH=800

DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
DASHBOARD_ENABLE_SYSTEMCTL=false
DASHBOARD_ENABLE_BACKUP=true

PHONE_AI_BASE_URL=http://192.168.0.50:8765
PHONE_AI_API_TOKEN=PUT_PHONE_AI_TOKEN_HERE
PHONE_AI_TIMEOUT_SECONDS=180
PHONE_AI_MAX_TOKENS=180
PHONE_AI_CHECK_MAX_TOKENS=48

COORDINATE_SYNC_TO_PHONE=true
COORDINATE_DB_PATH=/home/user/server/dashboard/dashboard.db
COORDINATE_DB_TABLE=coordinates
COORDINATE_SYNC_LIMIT=200
COORDINATE_SYNC_TTL_SECONDS=300

DASHBOARD_EVENT_TOKEN=PUT_EVENT_TOKEN_HERE
DASHBOARD_ENABLE_AI_EVENT_WORKER=true
DASHBOARD_ALLOW_UNAUTHENTICATED_EVENTS=false
DASHBOARD_ENABLE_RCON_COMMANDS=false
AI_CHAT_PREFIX=[AI]

MINECRAFT_RCON_HOST=127.0.0.1
MINECRAFT_RCON_PORT=25575
MINECRAFT_RCON_PASSWORD=PUT_RCON_PASSWORD_HERE
MINECRAFT_RCON_TIMEOUT_SECONDS=10

NAS_BACKUP_TARGET=user@192.168.0.20:/volume1/minecraft_backups/raspberry_pi
BACKUP_KEEP_COUNT=5
BACKUP_TIME=03:30
BACKUP_INTERVAL_DAYS=3
BACKUP_SKIP_CUTOFF=23:59
