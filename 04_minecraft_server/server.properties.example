# Minecraft Paper Server - Raspberry Pi 5
# Copy to server.properties and edit secrets locally.

server-port=25565
motd=Raspberry Pi 5 Minecraft Server
gamemode=survival
difficulty=normal
hardcore=false
pvp=true

max-players=5
white-list=true
enforce-whitelist=true
online-mode=true

view-distance=6
simulation-distance=4
spawn-protection=8

enable-command-block=false
allow-flight=false
allow-nether=true
spawn-animals=true
spawn-monsters=true
spawn-npcs=true

enable-rcon=true
rcon.port=25575
rcon.password=CHANGE_ME_FROM_ENV
enable-query=false

sync-chunk-writes=false
max-world-size=29999984

level-name=world
level-seed=
level-type=minecraft\:normal

generate-structures=true
enable-status=true
hide-online-players=false

player-idle-timeout=0
entity-broadcast-range-percentage=80

rate-limit=0
network-compression-threshold=256
