[Unit]
Description=Personal Memo FastAPI Site
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=user
WorkingDirectory=/home/user/Raspberry_Pi/09_personal_memo_site
EnvironmentFile=/home/user/Raspberry_Pi/09_personal_memo_site/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/user/Raspberry_Pi/09_personal_memo_site/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8009
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
