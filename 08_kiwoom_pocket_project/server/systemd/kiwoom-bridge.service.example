[Unit]
Description=Kiwoom Bridge FastAPI server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/kiwoom-pocket-project/server
EnvironmentFile=/opt/kiwoom-pocket-project/server/.env
ExecStart=/opt/kiwoom-pocket-project/server/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
