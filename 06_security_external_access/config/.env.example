# Security folder reference template.
# Root .env.example is the source of truth.

DASHBOARD_MODE=production
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD_HASH=PUT_GENERATED_PASSWORD_HASH_HERE
DASHBOARD_PASSWORD=
DASHBOARD_SECRET_KEY=PUT_LONG_RANDOM_SECRET_HERE
SESSION_SECRET=
SESSION_MAX_AGE_SECONDS=86400
COOKIE_SECURE=false

DASHBOARD_ENABLE_SYSTEMCTL=false
DASHBOARD_ENABLE_BACKUP=true

MINECRAFT_RCON_HOST=127.0.0.1
MINECRAFT_RCON_PORT=25575
MINECRAFT_RCON_PASSWORD=CHANGE_ME

PHONE_AI_BASE_URL=http://192.168.0.50:8080
PHONE_AI_API_TOKEN=CHANGE_ME
PHONE_AI_TIMEOUT_SECONDS=30

NAS_BACKUP_TARGET=user@192.168.0.20:/volume1/minecraft_backups/raspberry_pi
BACKUP_KEEP_COUNT=5

MINECRAFT_WHITELIST=true
MINECRAFT_ONLINE_MODE=true
